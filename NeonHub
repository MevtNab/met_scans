function Elements:AddSlider(text, min, max, default, callback)
    local SliderFrame = Instance.new("Frame", Page)
    SliderFrame.Size = UDim2.new(1, -5, 0, 60) -- Biraz daha genişlettik, daha ferah durur
    SliderFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 8)

    local Title = Instance.new("TextLabel", SliderFrame)
    Title.Text = "   " .. text
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.GothamMedium
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local ValueLabel = Instance.new("TextLabel", SliderFrame)
    ValueLabel.Text = tostring(default) .. " "
    ValueLabel.Size = UDim2.new(1, -12, 0, 30)
    ValueLabel.TextColor3 = Color3.fromRGB(0, 150, 255) -- Değer rengi daha canlı
    ValueLabel.BackgroundTransparency = 1
    ValueLabel.Font = Enum.Font.GothamBold
    ValueLabel.TextSize = 13
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

    local SliderBack = Instance.new("Frame", SliderFrame)
    SliderBack.Size = UDim2.new(1, -25, 0, 4) -- İnce ve zarif bir hat
    SliderBack.Position = UDim2.new(0, 12, 0, 42)
    SliderBack.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Instance.new("UICorner", SliderBack)

    local SliderFill = Instance.new("Frame", SliderBack)
    SliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    SliderFill.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    Instance.new("UICorner", SliderFill)

    -- Tutamaç (Knob)
    local Knob = Instance.new("Frame", SliderFill)
    Knob.Size = UDim2.new(0, 12, 0, 12)
    Knob.Position = UDim2.new(1, -6, 0.5, -6)
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    
    -- Görsel parlatma (Stroke)
    local Stroke = Instance.new("UIStroke", Knob)
    Stroke.Color = Color3.fromRGB(0, 150, 255)
    Stroke.Thickness = 2

    local dragging = false
    local UIS = game:GetService("UserInputService")
    local TS = game:GetService("TweenService")

    local function update(input)
        local pos = math.clamp((input.Position.X - SliderBack.AbsolutePosition.X) / SliderBack.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pos)
        
        -- Yumuşak hareket için Tween
        TS:Create(SliderFill, TweenInfo.new(0.1, Enum.EasingStyle.Quart), {
            Size = UDim2.new(pos, 0, 1, 0)
        }):Play()
        
        ValueLabel.Text = tostring(val) .. " "
        callback(val)
    end

    SliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    -- Hover Efekti
    SliderFrame.MouseEnter:Connect(function()
        TS:Create(SliderFrame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
        TS:Create(Stroke, TweenInfo.new(0.3), {Thickness = 3}):Play()
    end)

    SliderFrame.MouseLeave:Connect(function()
        TS:Create(SliderFrame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
        TS:Create(Stroke, TweenInfo.new(0.3), {Thickness = 2}):Play()
    end)
end

