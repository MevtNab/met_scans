-- BİLDİRİM SİSTEMİ (XenoLib'e eklendi)
function XenoLib:Notify(title, text, duration)
    local NotifyGui = game:GetService("CoreGui"):FindFirstChild("XenoNotifications")
    if not NotifyGui then
        NotifyGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
        NotifyGui.Name = "XenoNotifications"
    end

    local NotifFrame = Instance.new("Frame", NotifyGui)
    NotifFrame.Size = UDim2.new(0, 260, 0, 65)
    NotifFrame.Position = UDim2.new(1, 30, 1, -80)
    NotifFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 8)
    
    local TitleL = Instance.new("TextLabel", NotifFrame)
    TitleL.Text = "  " .. title
    TitleL.Size = UDim2.new(1, 0, 0, 25)
    TitleL.TextColor3 = Color3.fromRGB(0, 150, 255)
    TitleL.Font = Enum.Font.GothamBold
    TitleL.TextSize = 14
    TitleL.BackgroundTransparency = 1
    TitleL.TextXAlignment = Enum.TextXAlignment.Left

    local TextL = Instance.new("TextLabel", NotifFrame)
    TextL.Text = "  " .. text
    TextL.Size = UDim2.new(1, 0, 1, -25)
    TextL.Position = UDim2.new(0, 0, 0, 25)
    TextL.TextColor3 = Color3.fromRGB(200, 200, 200)
    TextL.Font = Enum.Font.GothamMedium
    TextL.TextSize = 12
    TextL.BackgroundTransparency = 1
    TextL.TextWrapped = true
    TextL.TextXAlignment = Enum.TextXAlignment.Left

    NotifFrame:TweenPosition(UDim2.new(1, -270, 1, -80), "Out", "Quart", 0.5, true)
    task.delay(duration or 3, function()
        NotifFrame:TweenPosition(UDim2.new(1, 30, 1, -80), "In", "Quart", 0.5, true)
        task.wait(0.5)
        NotifFrame:Destroy()
    end)
end

