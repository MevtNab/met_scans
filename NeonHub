        -- ELEMENT: SECTION (Listenin sonuna ekleyebilirsin)
        function Elements:AddSection(text)
            local SectionFrame = Instance.new("Frame", Page)
            SectionFrame.Size = UDim2.new(1, -5, 0, 35)
            SectionFrame.BackgroundTransparency = 1

            local SectionText = Instance.new("TextLabel", SectionFrame)
            SectionText.Text = string.upper(text)
            SectionText.Size = UDim2.new(1, 0, 1, 0)
            SectionText.TextColor3 = Color3.fromRGB(0, 150, 255)
            SectionText.Font = Enum.Font.GothamBold
            SectionText.TextSize = 18
            SectionText.BackgroundTransparency = 1
            SectionText.TextXAlignment = Enum.TextXAlignment.Left
            SectionText.Position = UDim2.new(0, 4, 0, 0)
            
            local Line = Instance.new("Frame", SectionFrame)
            Line.Size = UDim2.new(1, -10, 0, 1)
            Line.Position = UDim2.new(0, 5, 1, -2)
            Line.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Line.BorderSizePixel = 0
        end

        return Elements
    end

    return Library
end
