    PickerPanel.Size = UDim2.new(1, -20, 0, 80)
    PickerPanel.Position = UDim2.new(0, 10, 0, 50)
    PickerPanel.BackgroundTransparency = 1

    -- HUE (RENK) SLIDER
    local HueFrame = Instance.new("Frame", PickerPanel)
    HueFrame.Size = UDim2.new(1, 0, 0, 20)
    HueFrame.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", HueFrame)

    local HueGradient = Instance.new("UIGradient", HueFrame)
    HueGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
        ColorSequenceKeypoint.new(0.16, Color3.fromRGB(255, 255, 0)),
        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
        ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0, 0, 255)),
        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
    })

    -- PARLAKLIK (V) SLIDER
    local ValueFrame = Instance.new("Frame", PickerPanel)
    ValueFrame.Size = UDim2.new(1, 0, 0, 20)
    ValueFrame.Position = UDim2.new(0, 0, 0, 35)
    Instance.new("UICorner", ValueFrame)

    local ValueGradient = Instance.new("UIGradient", ValueFrame)
    
    -- MANTIK DEĞİŞKENLERİ
    local h, s, v = Color3.toHSV(default)
    local isOpen = false
    local UIS = game:GetService("UserInputService")

    local function update()
        local color = Color3.fromHSV(h, s, v)
        ColorPreview.BackgroundColor3 = color
        ValueGradient.Color = ColorSequence.new(Color3.new(1,1,1), Color3.fromHSV(h, 1, 1))
        callback(color)
    end

    -- SÜRÜKLEME FONKSİYONU (Daha stabil)
    local function setupSlider(frame, type)
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local connection
                connection = UIS.InputChanged:Connect(function(change)
                    if change.UserInputType == Enum.UserInputType.MouseMovement then
                        local rel = math.clamp((change.Position.X - frame.AbsolutePosition.X) / frame.AbsoluteSize.X, 0, 1)
                        if type == "h" then h = rel else v = rel end
                        update()
                    end
                end)
                UIS.InputEnded:Connect(function(ended)
                    if ended.UserInputType == Enum.UserInputType.MouseButton1 then
                        connection:Disconnect()
                    end
                end)
                -- İlk tıklama için:
                local rel = math.clamp((input.Position.X - frame.AbsolutePosition.X) / frame.AbsoluteSize.X, 0, 1)
                if type == "h" then h = rel else v = rel end
                update()
            end
        end)
    end

    setupSlider(HueFrame, "h")
    setupSlider(ValueFrame, "v")

    OpenBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        CPFrame:TweenSize(isOpen and UDim2.new(1, -5, 0, 115) or UDim2.new(1, -5, 0, 45), "Out", "Quart", 0.3, true)
    end)

    update() -- İlk açılışta rengi ayarla
end

