        TS:Create(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 22, 0, 16), -- Hareket anında biraz uzar
            Position = targetPos
        }):Play()
        
        task.delay(0.1, function()
            TS:Create(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 16, 0, 16) -- Durduğunda normale döner
            }):Play()
        end)

        -- Track Renk Animasyonu
        TS:Create(Track, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
            BackgroundColor3 = targetColor
        }):Play()

        callback(State)
    end)
    
    -- Hover Efektleri
    TglBtn.MouseEnter:Connect(function()
        TS:Create(TglBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
    end)

    TglBtn.MouseLeave:Connect(function()
        TS:Create(TglBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
    end)
end

